{
  "name": "theiaverse-backend",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun src/index.ts",
    "db:generate": "bun --env-file=.env ./node_modules/.bin/prisma generate",
    "db:push": "bun --env-file=.env ./node_modules/.bin/prisma db push",
    "db:migrate": "bun --env-file=.env ./node_modules/.bin/prisma migrate dev",
    "db:seed": "bun --env-file=.env ./node_modules/.bin/prisma db seed"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.2.3",
    "hono": "^4.12.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/compute-sdk": "latest",
    "@types/node": "^20.11.17",
    "prisma": "^7.8.0",
    "typescript": "^5.8.3"
  }
}
